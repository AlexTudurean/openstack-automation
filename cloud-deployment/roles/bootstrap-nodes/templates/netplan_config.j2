network:
  version: 2
  renderer: networkd
  ethernets:
{% for interface in ethernets %}
    {{ interface.link }}:
      addresses: {{ interface.addresses }}
{% if interface.routes is defined %}
      routes:
{% for route in interface.routes %}
        - to: {{ route.to }}
          via: {{ route.via }}
{% endfor %}
{% endif %}
{% if interface.nameservers is defined %}
      nameservers:
        addresses: {{ interface.nameservers.addresses }}
{% endif %}
{% endfor %}
{% if vlans is defined %}
  vlans:
{% for vlan in vlans %}
    {{ vlan.link }}.{{ vlan.vlan_id }}:
      id: {{ vlan.vlan_id }}
      link: {{ vlan.link }}
      mtu: {{ vlan.mtu }}
{% if vlan.addresses is defined %}
      addresses: {{ vlan.addresses }}
{% endif %}
{% if vlan.routes is defined %}
      routes:
{% for route in vlan.routes %}
        - to: {{ route.to }}
          via: "{{ route.via }}"
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
