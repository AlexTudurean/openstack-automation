#cloud-config
packages:
  - wireguard
  - dnsmasq
  - iptables

write_files:
  - path: /etc/wireguard/wg0.conf
    permissions: '0600'
    content: |
      [Interface]
      Address    = {{ vpn_gateway_tunnel_server_ip }}
      ListenPort = {{ vpn_gateway_wg_port }}
      PrivateKey = {{ wg_server_private_key }}

      # TCPMSS clamp in BOTH directions: tenant VMs sit behind an OpenStack
      # VXLAN net (1350 MTU); clamping every forwarded SYN/SYN-ACK to the path
      # MTU stops large packets (e.g. the SSH KEX_ECDH_REPLY) being blackholed
      # regardless of what either endpoint advertises. Backstop to the correct
      # global_physnet_mtu in globals.yml.
      PostUp   = iptables -A FORWARD -i wg0 -o ens3 -d {{ vpn_gateway_routed_subnet }} -j ACCEPT; iptables -A FORWARD -i ens3 -o wg0 -s {{ vpn_gateway_routed_subnet }} -j ACCEPT; iptables -t mangle -A FORWARD -i wg0 -o ens3 -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu; iptables -t mangle -A FORWARD -i ens3 -o wg0 -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
      PostDown = iptables -D FORWARD -i wg0 -o ens3 -d {{ vpn_gateway_routed_subnet }} -j ACCEPT; iptables -D FORWARD -i ens3 -o wg0 -s {{ vpn_gateway_routed_subnet }} -j ACCEPT; iptables -t mangle -D FORWARD -i wg0 -o ens3 -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu; iptables -t mangle -D FORWARD -i ens3 -o wg0 -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu

  - path: /etc/dnsmasq.d/vpn-gateway.conf
    content: |
      interface=wg0
      # bind-dynamic (not bind-interfaces) so dnsmasq starts even if wg0 does
      # not exist yet and binds to it when it appears. With bind-interfaces,
      # dnsmasq aborts at boot with "unknown interface wg0" whenever it wins the
      # startup race against wg-quick@wg0, leaving VPN users with no DNS.
      bind-dynamic
      server=8.8.8.8
      server=8.8.4.4
      expand-hosts
      domain=cloud.internal
      no-dhcp-interface=wg0

  # Belt-and-suspenders ordering: start dnsmasq after the WireGuard interface.
  - path: /etc/systemd/system/dnsmasq.service.d/10-after-wireguard.conf
    content: |
      [Unit]
      After=wg-quick@wg0.service
      Wants=wg-quick@wg0.service

runcmd:
  - echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf
  - sysctl -p
  - systemctl enable --now wg-quick@wg0
  - systemctl daemon-reload
  - systemctl enable dnsmasq
  - systemctl restart dnsmasq
